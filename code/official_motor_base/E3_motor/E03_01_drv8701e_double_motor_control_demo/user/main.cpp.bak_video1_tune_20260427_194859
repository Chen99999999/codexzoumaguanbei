#include "smartcar_motor.hpp"
#include "smartcar_display.hpp"
#include "smartcar_camera.hpp"
#include "smartcar_line.hpp"
#include "smartcar_encoder.hpp"
#include "smartcar_speed.hpp"

#include <stdio.h>
#include <unistd.h>
#include <signal.h>

static volatile int g_running = 1;

static void delay_ms(int ms)
{
    usleep(ms * 1000);
}

static int clamp_i(int v, int lo, int hi)
{
    if (v < lo) return lo;
    if (v > hi) return hi;
    return v;
}

static void on_signal(int)
{
    g_running = 0;
    speed_control_stop();
    motor_stop();
}

static void show_debug_light(const smartcar_line_result_t &line, int ce, int lt, int rt)
{
    // 实车模式不要每帧刷灰度图，避免延迟
    display_line(0, "REAL LINE");
    display_value(1, "V",  line.valid);
    display_value(2, "CX", line.center_x);
    display_value(3, "CE", ce);
    display_value(4, "LT", lt);
    display_value(5, "RT", rt);
    display_value(6, "ML", speed_control_get_left_measured());
    display_value(7, "MR", speed_control_get_right_measured());
}

int main(int, char **)
{
    printf("\n========== SMARTCAR REALTIME CENTER LINE ==========\n");
    printf("[CTRL] Ctrl+C stop motor.\n");

    signal(SIGINT, on_signal);
    signal(SIGTERM, on_signal);

    motor_init();
    motor_stop();

    encoder_init();
    encoder_clear();

    display_init();
    display_clear();
    display_line(0, "REAL LINE");

    if (!camera_init())
    {
        printf("[main] camera_init failed\n");
        display_line(1, "CAM FAIL");

        while (1)
        {
            motor_stop();
            delay_ms(1000);
        }
    }

    printf("[main] camera ok, size=%dx%d\n", camera_get_width(), camera_get_height());

    line_init();

    speed_control_init(100);
    speed_control_stop();

    // line_debug 数据说明：CX 是白色赛道主体中心，目标回到图像中心
    const int TARGET_X = 80;

    // 太小会死，直接提高基础速度
    const int BASE_TARGET = 1700;

    // 右转之前过强，右转增益低一点
    // 左转依赖右轮，右轮容易卡，所以左转增益高一点
    const int LINE_K_RIGHT = 7;     // CE > 0，需要右转
    const int LINE_K_LEFT  = 20;    // CE < 0，需要左转

    const int TURN_LIMIT  = 1300;
    const int TARGET_MAX  = 3200;
    const int TARGET_DEAD = 900;

    // 需要左转时，右轮强制给够目标，防止右轮低速死区卡住
    const int RIGHT_MIN_WHEN_LEFT_TURN = 2300;

    int frame_count = 0;
    int lost_count = 0;

    while (g_running)
    {
        if (!camera_update())
        {
            printf("[main] camera_update failed\n");
            speed_control_set_target(0, 0);
            speed_control_update();
            motor_stop();
            delay_ms(100);
            continue;
        }

        line_update();
        smartcar_line_result_t line = line_get_result();

        int w = camera_get_width();

        int left_target = 0;
        int right_target = 0;
        int control_error = 0;

        if (line.valid && line.center_x >= 0 && line.center_x < w)
        {
            lost_count = 0;

            control_error = line.center_x - TARGET_X;

            int k = (control_error > 0) ? LINE_K_RIGHT : LINE_K_LEFT;
            int turn = k * control_error;
            turn = clamp_i(turn, -TURN_LIMIT, TURN_LIMIT);

            // CE > 0：赛道中心在右边，需要右转：左轮快，右轮慢
            // CE < 0：赛道中心在左边，需要左转：左轮慢，右轮快
            left_target  = BASE_TARGET + turn;
            right_target = BASE_TARGET - turn;

            left_target  = clamp_i(left_target,  0, TARGET_MAX);
            right_target = clamp_i(right_target, 0, TARGET_MAX);

            // 小目标直接归零，避免半死不活低速
            if (left_target > 0 && left_target < TARGET_DEAD)
            {
                left_target = 0;
            }

            if (right_target > 0 && right_target < TARGET_DEAD)
            {
                right_target = 0;
            }

            // 关键补偿：需要左转时，右轮必须给足
            if (control_error < -8 && right_target < RIGHT_MIN_WHEN_LEFT_TURN)
            {
                right_target = RIGHT_MIN_WHEN_LEFT_TURN;
            }
        }
        else
        {
            lost_count++;
            left_target = 0;
            right_target = 0;
        }

        speed_control_set_target(left_target, right_target);
        speed_control_update();

        if ((frame_count % 5) == 0)
        {
            show_debug_light(line, control_error, left_target, right_target);

            printf("[real] V=%d lost=%d W=%d CX=%d rawE=%d CE=%d LT=%d RT=%d ML=%d MR=%d LPWM=%d RPWM=%d\n",
                   line.valid,
                   lost_count,
                   w,
                   line.center_x,
                   line.error,
                   control_error,
                   left_target,
                   right_target,
                   speed_control_get_left_measured(),
                   speed_control_get_right_measured(),
                   speed_control_get_left_pwm_x100(),
                   speed_control_get_right_pwm_x100());
        }

        frame_count++;

        // speed_control 是 100ms 采样，主循环先保持 100ms
        delay_ms(100);
    }

    speed_control_stop();
    motor_stop();

    printf("[main] stopped\n");
    return 0;
}
